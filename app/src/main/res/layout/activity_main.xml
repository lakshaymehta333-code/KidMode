<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="😴 PhoneNap"
            android:textSize="30sp"
            android:textColor="#888888"
            android:fontFamily="sans-serif-light"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Screen-nap mode for kids. No PIN, no Device Admin. Parent fingerprint unlocks."
            android:textSize="13sp"
            android:textColor="#444444"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="36dp"/>

        <!-- Step 1 — Accessibility -->
        <TextView
            android:id="@+id/tvAccessibilityStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="❌ Accessibility Service: Not enabled"
            android:textColor="#777777"
            android:textSize="13sp"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btnEnableAccessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Step 1 — Enable Accessibility Service"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="In Accessibility settings, find PhoneNap Overlay and turn it ON."
            android:textColor="#3A3A3A"
            android:textSize="12sp"
            android:layout_marginBottom="32dp"/>

        <!-- Step 2 — Biometric -->
        <TextView
            android:id="@+id/tvBiometricStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ Biometric: Ready"
            android:textColor="#777777"
            android:textSize="13sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Step 2 — If not enrolled: Settings → Security → Fingerprint."
            android:textColor="#3A3A3A"
            android:textSize="12sp"
            android:layout_marginBottom="32dp"/>

        <!-- Step 3 — Add tile -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Step 3 — Add PhoneNap to Quick Settings"
            android:textColor="#777777"
            android:textSize="13sp"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pull down twice → tap the pencil icon → drag 😴 PhoneNap into the tile row."
            android:textColor="#3A3A3A"
            android:textSize="12sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="40dp"/>

        <!-- How to use -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="How to use"
            android:textColor="#555555"
            android:textSize="14sp"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• Tap 😴 PhoneNap in Quick Settings to activate\n• Screen goes grayscale and dims over 45 seconds\n• Phone locks itself to sleep\n• Kid presses power → overlay fires instantly\n• Tap the fingerprint icon → parent unlocks with biometric\n• Tile tap (when ON) also triggers parent biometric"
            android:textColor="#3A3A3A"
            android:textSize="12sp"
            android:lineSpacingExtra="5dp"/>

    </LinearLayout>
</ScrollView>
