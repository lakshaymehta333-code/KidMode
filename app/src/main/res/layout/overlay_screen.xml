<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="false">

    <!-- Clock -->
    <TextView
        android:id="@+id/tvClock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="100dp"
        android:text="12:00"
        android:textColor="#1A1A1A"
        android:textSize="72sp"
        android:fontFamily="sans-serif-thin"
        android:letterSpacing="0.05"/>

    <!-- Centre: icon + message + unlock button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingLeft="40dp"
        android:paddingRight="40dp">

        <ImageView
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/ic_tile"
            android:alpha="0.20"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Phone is napping"
            android:textColor="#252525"
            android:textSize="22sp"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.02"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Show parent face to unlock"
            android:textColor="#191919"
            android:textSize="13sp"
            android:fontFamily="sans-serif-light"/>

        <!-- Unlock button: parent looks at camera -->
        <FrameLayout
            android:id="@+id/btnUnlock"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginTop="48dp"
            android:background="@drawable/circle_bg"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_fingerprint"
                android:alpha="0.5"/>

        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="PARENT UNLOCK"
            android:textColor="#1A1A1A"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:fontFamily="sans-serif-medium"/>

    </LinearLayout>

    <!-- Branding -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="40dp"
        android:text="PhoneNap"
        android:textColor="#111111"
        android:textSize="11sp"
        android:letterSpacing="0.2"
        android:fontFamily="sans-serif-medium"/>

</FrameLayout>
