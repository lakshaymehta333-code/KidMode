<?xml version="1.0" encoding="utf-8"?>
<!--
    The boring screen. Intentionally dull: flat grey, no colour, no animation.
    The invisible top-right corner (parentUnlockArea) is the hidden long-press target
    for the parent to open the PIN unlock screen.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/boring_bg">

    <!-- Invisible long-press unlock target: top-right 64 dp square -->
    <View
        android:id="@+id/parentUnlockArea"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="top|end"
        android:background="@android:color/transparent"
        android:contentDescription="Parent access" />

    <!-- Centred content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp">

        <!-- Large clock -->
        <TextView
            android:id="@+id/tvClock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textSize="80sp"
            android:textColor="@color/boring_text_primary"
            android:fontFamily="sans-serif-thin"
            android:includeFontPadding="false"
            android:layout_marginBottom="56dp" />

        <!-- Primary message -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Screen time is over."
            android:textSize="20sp"
            android:textColor="@color/boring_text_primary"
            android:layout_marginBottom="12dp" />

        <!-- Secondary message -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Time for a break."
            android:textSize="15sp"
            android:textColor="@color/boring_text_secondary"
            android:layout_marginBottom="48dp" />

        <!-- Hairline divider -->
        <View
            android:layout_width="32dp"
            android:layout_height="1dp"
            android:background="@color/boring_divider"
            android:layout_marginBottom="48dp" />

        <!-- Nudge -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Put the phone down."
            android:textSize="13sp"
            android:textColor="@color/boring_text_secondary" />

    </LinearLayout>

</FrameLayout>
